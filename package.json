{
  "name": "tanaga-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Express-based Tanaga agent with local document embeddings for RAG",
  "main": "server.bundle.js",
  "scripts": {
    "build": "esbuild server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=server.bundle.js",
    "dev": "tsx watch server.ts",
    "start": "node server.bundle.js",
    "rag:index": "tsx src/scripts/rebuildEmbeddings.ts",
    "rag:build": "tsx src/scripts/rebuildEmbeddings.ts",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mammoth": "^1.9.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.23",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
